{
  "id": null,
  "title": "R-Pingmesh Simulation Overview",
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Simulated RTT (ns)",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(rpingmesh_simulated_rtt_nanoseconds_sum[1m]) / rate(rpingmesh_simulated_rtt_nanoseconds_count[1m])",
          "legendFormat": "RTT mean",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Timeout Count",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(rpingmesh_simulated_timeout_total[1m])",
          "legendFormat": "timeouts/min",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Prober Delay Mean (ns)",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(rpingmesh_simulated_prober_delay_nanoseconds_sum[1m]) / rate(rpingmesh_simulated_prober_delay_nanoseconds_count[1m])",
          "legendFormat": "prober delay",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Responder Delay Mean (ns)",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(rpingmesh_simulated_responder_delay_nanoseconds_sum[1m]) / rate(rpingmesh_simulated_responder_delay_nanoseconds_count[1m])",
          "legendFormat": "responder delay",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"}
}

