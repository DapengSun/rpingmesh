# OpenTelemetry Collector 配置示例
# 复制此文件到配置目录并重命名为 otel-collector-config.yaml
#
# 此配置支持：
# 1. 数据持久化（file_storage）- 队列溢出时落盘，重启可恢复
# 2. 内存限流（memory_limiter）- 防止 OOM，需按容器内存调整 limit_mib
# 3. 导出重试（retry_on_failure）- 临时故障时重试，减少丢数
#
# 生产环境建议关闭 debug；调试时可取消注释 debug 并加入 pipeline.exporters

receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
      http:
        endpoint: 0.0.0.0:4318

processors:
  # 必须放在 pipeline 第一位：内存超限时背压，避免 OOM（按容器内存调整）
  memory_limiter:
    check_interval: 1s
    limit_mib: 400
    spike_limit_mib: 100
  batch:
    timeout: 10s
    send_batch_size: 2048
  resource:
    attributes:
      - key: deployment.environment
        value: "production"
        action: upsert

extensions:
  file_storage:
    directory: /app/data/storage

exporters:
  # debug:
  #   verbosity: basic

  prometheus:
    endpoint: "0.0.0.0:8889"
    const_labels:
      service: "rpingmesh-collector"
    sending_queue:
      enabled: true
      num_consumers: 10
      queue_size: 50000
      storage: file_storage
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_interval: 30s
      max_elapsed_time: 300s

service:
  extensions: [file_storage]
  pipelines:
    metrics:
      receivers: [otlp]
      processors: [memory_limiter, batch, resource]
      exporters: [prometheus]

