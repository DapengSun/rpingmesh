# OpenTelemetry Collector 配置示例
# 复制此文件到配置目录并重命名为 otel-collector-config.yaml
#
# 此配置支持：
# 1. 数据持久化（file_storage）- 队列溢出时落盘，重启可恢复
# 2. 内存限流（memory_limiter）- 防止 OOM，需按容器内存调整 limit_mib
#
# 生产环境建议关闭 debug；调试时可取消注释 debug 并加入 pipeline.exporters

receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
      http:
        endpoint: 0.0.0.0:4318

processors:
  # 仅过滤 delay 的 histogram，减轻 pipeline 压力（RTT 保留，用于平均值/分位数）
  filter/drop_delay_histograms:
    metrics:
      exclude:
        match_type: strict
        metric_names:
          - rpingmesh.prober_delay
          - rpingmesh.responder_delay
  # 必须放在 pipeline 第一位：内存超限时背压，避免 OOM（按容器内存调整）
  memory_limiter:
    check_interval: 1s
    limit_mib: 400
    spike_limit_mib: 100
  batch:
    timeout: 10s
    send_batch_size: 2048
  resource:
    attributes:
      - key: deployment.environment
        value: "production"
        action: upsert

extensions:
  file_storage:
    directory: /app/data/storage

exporters:
  # debug:
  #   verbosity: basic

  prometheus:
    endpoint: "0.0.0.0:8889"
    const_labels:
      service: "rpingmesh-collector"
    sending_queue:
      enabled: true
      num_consumers: 10
      queue_size: 50000
      storage: file_storage

service:
  extensions: [file_storage]
  pipelines:
    metrics:
      receivers: [otlp]
      processors: [memory_limiter, filter/drop_delay_histograms, batch, resource]
      exporters: [prometheus]

