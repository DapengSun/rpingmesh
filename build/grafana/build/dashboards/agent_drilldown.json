{
  "id": null,
  "title": "R-Pingmesh Agent Drilldown",
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "tags": ["rpingmesh"],
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Agent Avg RTT (ns)",
      "datasource": null,
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 4},
      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "decimals": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 120000000},
              {"color": "red", "value": 200000000}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "text": {}
      },
      "targets": [
        {
          "expr": "sum(increase(rpingmesh_nwrtt_nanoseconds_sum{src_agent_id=~\"$src_agent\"}[5m])) / sum(increase(rpingmesh_nwrtt_nanoseconds_count{src_agent_id=~\"$src_agent\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Agent Timeouts per Minute（次/分钟）",
      "datasource": null,
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 4},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "text": {}
      },
      "targets": [
        {
          "expr": "sum(rate(rpingmesh_timeout_total{src_agent_id=~\"$src_agent\"}[5m])) * 60",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "RTT Mean by Destination",
      "datasource": null,
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "sum(increase(rpingmesh_nwrtt_nanoseconds_sum{src_agent_id=~\"$src_agent\"}[5m])) by (dst_agent_id) / sum(increase(rpingmesh_nwrtt_nanoseconds_count{src_agent_id=~\"$src_agent\"}[5m])) by (dst_agent_id)",
          "legendFormat": "{{dst_agent_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 200000000}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Timeout Rate by Destination（次/分钟）",
      "datasource": null,
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(rpingmesh_timeout_total{src_agent_id=~\"$src_agent\"}[5m]) * 60) by (dst_agent_id)",
          "legendFormat": "{{dst_agent_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Destination Summary",
      "datasource": null,
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "topk(5, sum(increase(rpingmesh_nwrtt_nanoseconds_sum{src_agent_id=~\"$src_agent\"}[5m])) by (dst_agent_id) / sum(increase(rpingmesh_nwrtt_nanoseconds_count{src_agent_id=~\"$src_agent\"}[5m])) by (dst_agent_id)) / 1e6",
          "format": "table",
          "instant": true,
          "legendFormat": "{{dst_agent_id}} rtt",
          "refId": "A"
        },
        {
          "expr": "topk(5, sum(rate(rpingmesh_timeout_total{src_agent_id=~\"$src_agent\"}[5m]) * 60) by (dst_agent_id))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{dst_agent_id}} timeouts",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 200}
            ]
          },
          "unit": "ms",
          "decimals": 1
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value #B"
            },
            "properties": [
              {"id": "unit", "value": "short"},
              {"id": "decimals", "value": 2},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "orange", "value": 5},
                    {"color": "red", "value": 20}
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false,
          "countRows": false,
          "fields": "",
          "calcs": []
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "src_agent",
        "label": "Source Agent",
        "type": "query",
        "datasource": null,
        "definition": "label_values(rpingmesh_nwrtt_nanoseconds_sum, src_agent_id)",
        "query": "label_values(rpingmesh_nwrtt_nanoseconds_sum, src_agent_id)",
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "regex": "",
        "skipUrlSync": false
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"}
}

