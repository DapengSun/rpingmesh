{
  "id": null,
  "title": "R-Pingmesh Cluster Overview",
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "tags": ["rpingmesh"],
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Cluster Avg RTT (ns)",
      "datasource": null,
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 4},
      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "decimals": 0,
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 120000000},
              {"color": "red", "value": 200000000}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "text": {}
      },
      "targets": [
        {
          "expr": "sum(increase(rpingmesh_nwrtt_nanoseconds_sum[5m])) / sum(increase(rpingmesh_nwrtt_nanoseconds_count[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Timeouts per Minute（次/分钟）",
      "datasource": null,
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 4},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "text": {}
      },
      "targets": [
        {
          "expr": "sum(rate(rpingmesh_timeout_total[5m]) * 60)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "RTT Mean by Probe Type",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "sum(increase(rpingmesh_nwrtt_nanoseconds_sum[5m])) by (probe_type) / sum(increase(rpingmesh_nwrtt_nanoseconds_count[5m])) by (probe_type)",
          "legendFormat": "{{probe_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 200000000}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Timeout Rate by Probe Type（次/分钟）",
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(rpingmesh_timeout_total[5m]) * 60) by (probe_type)",
          "legendFormat": "{{probe_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Top Destinations by Timeout",
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "topk(5, sum(rate(rpingmesh_timeout_total[5m]) * 60) by (dst_agent_id))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{dst_agent_id}} timeouts",
          "refId": "A"
        },
        {
          "expr": "topk(5, sum(increase(rpingmesh_nwrtt_nanoseconds_sum[5m])) by (dst_agent_id) / sum(increase(rpingmesh_nwrtt_nanoseconds_count[5m])) by (dst_agent_id))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{dst_agent_id}} rtt",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 200000000}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    }
  ],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"}
}

